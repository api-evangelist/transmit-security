          "type": "number",
          "description": "The bottom margin of captured area on image"
        },
        "left": {
          "type": "number",
          "description": "The left margin of captured area on image"
        },
        "right": {
          "type": "number",
          "description": "The right margin of captured area on image"
        }
      },
      "required": [
        "top",
        "bottom",
        "left",
        "right"
      ]
