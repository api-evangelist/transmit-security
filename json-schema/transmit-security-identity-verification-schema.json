    "AddImagesResponse": {
      "type": "object",
      "properties": {
        "feedback": {
          "type": "string",
          "description": "Feedback for the submitted image",
          "enum": [
            "ok",
            "other",
            "document_not_found",
            "face_not_found",
            "document_face_not_found",
            "obstructed",
            "blur",
            "glare",
            "document_not_supported",
            "document_not_matching",
            "wrong_document_side",
            "multi_face",
            "face_rotated",
            "face_too_small",
            "face_too_close",
            "closed_eyes",
            "face_angle_too_large",
            "face_close_to_border",
            "face_occluded",
            "face_cropped",
            "barcode_not_found",
            "glare_selfie",
            "blur_selfie",
            "restricted_criteria"
          ]
